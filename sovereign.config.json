{
    "$schema":  "https://raw.githubusercontent.com/tejaswin-amara/schema/main/config-v15.0.0.json",
    "version":  "15.0.3-Pure",
    "name":  "Sovereign Core Config",
    "core_axioms":  [
                        "ponytail",
                        "ponytail-audit",
                        "ponytail-debt"
                    ],
    "description":  "Unified configuration for the Sovereign Master Controller. Single source of truth.",
    "security_policy":  {
                            "allow_pattern":  "^[a-zA-Z0-9_-]{2,50}$",
                            "deny_patterns":  [
                                                  "\\.\\./",
                                                  "^/",
                                                  "\\\\",
                                                  "\\$\\(",
                                                  "eval\\(",
                                                  "exec\\("
                                              ],
                            "max_skill_name_length":  50
                        },
    "paths":  {
                  "skills_root":  "C:/Skills",
                  "core_file":  "SOVEREIGN_CORE.md",
                  "core_template":  "SOVEREIGN_CORE.template.md",
                  "version_file":  "VERSION",
                  "logs_dir":  "LOGS"
              },
    "governance":  {
                       "skills_count":  3,
                       "_skills_count_note":  "DYNAMIC - overwritten by sovereign.ps1 at runtime. Never edit manually.",
                       "lock_timeout_seconds":  5,
                       "log_retention_days":  7,
                       "log_max_size_mb":  10,
                       "harvester_excluded_dirs":  [
                                                       ".git",
                                                       ".agents",
                                                       ".cloud-cache",
                                                       ".agent-reach-venv",
                                                       ".venv",
                                                       "LOGS",
                                                       "skills"
                                                   ]
                   }
}

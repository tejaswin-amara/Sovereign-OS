{
  "$schema": "https://raw.githubusercontent.com/tejaswin-amara/schema/main/config-v14.0.0.json",
  "version": "15.0.0-CloudNative",
  "name": "Sovereign Skills Library",
  "core_axioms": [
    "ponytail",
    "ponytail-audit",
    "ponytail-debt",
    "ponytail-gain",
    "ponytail-help",
    "ponytail-review"
  ],
  "description": "Unified configuration for the Sovereign Master Controller. Single source of truth.",
  "security_policy": {
    "allow_pattern": "^[a-zA-Z0-9_-]{2,50}$",
    "deny_patterns": [
      "\\.\\./",
      "^/",
      "\\\\",
      "\\$\\(",
      "eval\\(",
      "exec\\("
    ],
    "max_skill_name_length": 50
  },
  "paths": {
    "skills_root": "C:/Skills",
    "core_file": "SOVEREIGN_CORE.md",
    "core_template": "SOVEREIGN_CORE.template.md",
    "version_file": "VERSION",
    "logs_dir": "LOGS",
    "lock_file": ".sovereign.lock"
  },
  "scripts": {
    "sovereign": "sovereign.ps1",
    "sovereign_check": "sovereign-check.ps1",
    "security_sweep": "agent-bootstrap/scripts/security-sweep.ps1",
    "skill_harvester": "agent-bootstrap/scripts/skill-harvester.ps1",
    "validate_skill": "agent-bootstrap/scripts/validate-skill.ps1",
    "install_agent_reach": "agent-bootstrap/scripts/Install-AgentReach.ps1",
    "fetch_cloud_skill": "agent-bootstrap/scripts/Fetch-CloudSkill.ps1",
    "self_evolve": "agent-bootstrap/scripts/self-evolve.ps1",
    "update_checksum": "agent-bootstrap/scripts/update-checksum.ps1",
    "helpers": "agent-bootstrap/scripts/helpers.psm1",
    "invoke_jules": "agent-bootstrap/scripts/Invoke-JulesSession.ps1",
    "wait_jules": "agent-bootstrap/scripts/Wait-JulesSession.ps1",
    "install_jules_cli": "agent-bootstrap/scripts/Install-JulesCLI.ps1",
    "webhook_jules": "agent-bootstrap/scripts/Start-JulesWebhookListener.ps1"
  },
  "governance": {
    "module_cap": 32,

    "skills_count": 7,
    "_skills_count_note": "DYNAMIC - overwritten by sovereign.ps1 at runtime. Never edit manually.",
    "lock_timeout_seconds": 30,
    "lock_lease_timeout_seconds": 600,
    "drift_tolerance": "LOW",
    "maintenance_only": false,
    "log_retention_days": 7,
    "log_max_size_mb": 10,
    "harvester_excluded_dirs": [
      ".git",
      ".agents",
      ".archive-v1.0",
      ".quarantine",
      ".cloud-cache",
      ".agent-reach-venv",
      ".venv",
      "__pycache__",
      "agent-bootstrap",
      "core-frameworks",
      "LOGS",
      "node_modules",
      "scratch",
      "templates",
      "servers",
      "skills",
      "dist",
      "build",
      ".next"
    ],
    "persistent_knowledge": [
      "C:/Skills/core-frameworks"
    ],
    "mcp_bindings": {
      "_note": "Advisory only - read by LLMs to determine capabilities, not enforced by Sovereign core scripts",
      "servers": [
        "fetch",
        "puppeteer",
        "filesystem"
      ]
    }
  },
  "harvester": {
    "scan_subdirs_on_no_root_manifest": true,
    "monorepo_subdirs": [
      "apps",
      "packages",
      "services"
    ],
    "manifest_files": [
      "package.json",
      "requirements.txt",
      "pyproject.toml",
      "pom.xml",
      "Cargo.toml",
      "go.mod"
    ],
    "excluded_scan_dirs": [
      "node_modules",
      ".git",
      ".agents",
      "dist",
      "build",
      ".next"
    ]
  },
  "dep_to_skill_map": {
    "next": "vercel/next.js",
    "react": "facebook/react",
    "drizzle": "drizzle-team/drizzle-orm",
    "drizzle-orm": "drizzle-team/drizzle-orm",
    "tailwind": "tailwindlabs/tailwindcss",
    "tailwindcss": "tailwindlabs/tailwindcss",
    "trpc": "trpc/trpc",
    "@trpc/server": "trpc/trpc",
    "zod": "colinhacks/zod",
    "hono": "honojs/hono",
    "turbo": "vercel/turbo",

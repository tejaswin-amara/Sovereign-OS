{
  "$schema": "https://raw.githubusercontent.com/sovereign-skills/schema/main/config-v13.2.0.json",
  "version": "13.2.0-CloudNative",
  "name": "Sovereign Skills Library",
  "description": "Unified configuration for the Sovereign Master Controller. Single source of truth.",
  "security_policy": {
    "allow_pattern": "^[a-zA-Z0-9_-]{2,50}$",
    "deny_patterns": [
      "\\.\\./",
      "^/",
      "\\\\",
      "\\$\\(",
      "eval\\(",
      "exec\\("
    ],
    "max_skill_name_length": 50,
    "require_signature": false
  },
  "paths": {
    "skills_root": "D:/Skills",
    "core_file": "SOVEREIGN_CORE.md",
    "core_template": "SOVEREIGN_CORE.template.md",
    "version_file": "VERSION",
    "logs_dir": "LOGS",
    "lock_file": ".sovereign.lock"
  },
  "scripts": {
    "sovereign": "sovereign.ps1",
    "sovereign_check": "sovereign-check.ps1",
    "security_sweep": "agent-bootstrap/scripts/security-sweep.ps1",
    "skill_harvester": "agent-bootstrap/scripts/skill-harvester.ps1",
    "validate_skill": "agent-bootstrap/scripts/validate-skill.ps1",
    "install_agent_reach": "agent-bootstrap/scripts/Install-AgentReach.ps1",
    "fetch_cloud_skill": "agent-bootstrap/scripts/Fetch-CloudSkill.ps1"
  },
  "governance": {
    "module_cap": 32,
    "skills_count": 0,
    "_skills_count_note": "DYNAMIC - overwritten by sovereign.ps1 at runtime. Never edit manually.",
    "lock_timeout_seconds": 30,
    "lock_lease_timeout_seconds": 600,
    "drift_tolerance": "LOW",
    "maintenance_only": false,
    "log_retention_days": 7,
    "log_max_size_mb": 10,
    "harvester_excluded_dirs": [
      ".git",
      ".agents",
      ".archive-v1.0",
      ".quarantine",
      "agent-bootstrap",
      "LOGS",
      "scratch",
      "templates",
      "G0DM0D3",
      "GodMode",
      "goose",
      "servers",
      ".cloud-cache"
    ]
  },
  "mcp_bindings": {
    "allowed": [
      "browsermcp",
      "StitchMCP",
      "exa"
    ],
    "forbidden": [
      "*"
    ],
    "_note": "Only listed MCPs may be invoked. All others are denied."
  },
  "harvester": {
    "scan_subdirs_on_no_root_manifest": true,
    "monorepo_subdirs": [
      "apps",
      "packages",
      "services"
    ],
    "manifest_files": [
      "package.json",
      "requirements.txt",
      "pom.xml",
      "Cargo.toml",
      "go.mod"
    ],
    "excluded_scan_dirs": [
      "node_modules",
      ".git",
      ".agents",
      "dist",
      "build",
      ".next"
    ]
  },
  "dep_to_skill_map": {
    "next": "next.js",
    "react": "awesome-react",
    "drizzle": "drizzle-orm",
    "drizzle-orm": "drizzle-orm",
    "tailwind": "tailwind-css",
    "tailwindcss": "tailwind-css",
    "trpc": "trpc",
    "@trpc/server": "trpc",
    "zod": "zod",
    "hono": "hono",
    "turbo": "turborepo",
    "playwright": "playwright",
    "@playwright/test": "playwright",
    "better-auth": "better-auth",
    "lucia": "lucia",
    "expo": "expo",
    "bullmq": "bullmq",
    "fastify": "fastify",
    "astro": "astro",
    "svelte": "svelte",
    "payload": "payload",
    "keycloak": "keycloak",
    "fastapi": "fastapi",
    "go": "go-patterns",
    "rag": "rag-search",
    "bun": "bun",
    "bun-types": "bun",
    "@biomejs/biome": "biome",
    "biome": "biome",
    "ai": "vercel-ai-sdk",
    "@ai-sdk/openai": "vercel-ai-sdk",
    "@ai-sdk/anthropic": "vercel-ai-sdk",
    "@supabase/supabase-js": "supabase",
    "supabase": "supabase",
    "@temporalio/client": "temporal",
    "@temporalio/worker": "temporal",
    "prisma": "prisma",
    "@prisma/client": "prisma",
    "vitest": "vitest",
    "jest": "jest",
    "express": "express",
    "zustand": "zustand",
    "framer-motion": "framer-motion",
    "tauri": "tauri",
    "@tauri-apps/api": "tauri",
    "typespec": "typespec",
    "@typespec/compiler": "typespec",
    "recharts": "awesome-react",
    "firebase": "awesome-react",
    "@google/genai": "google",
    "@capacitor/app": "android",
    "@capacitor/dialog": "android",
    "@capacitor/camera": "android",
    "@capacitor/cli": "android",
    "react-dom": "awesome-react",
    "vite": "vite",
    "@vitejs/plugin-react": "vite",
    "vite-plugin-pwa": "vite",
    "browser-use": "browser-use/browser-use",
    "stagehand": "browserbase/stagehand",
    "mem0": "mem0ai/mem0",
    "zep": "getzep/zep",
    "e2b": "e2b-dev/E2B",
    "daytona": "daytonaio/daytona",
    "autogen": "microsoft/autogen",
    "crewai": "crewAIInc/crewAI"
  }
}

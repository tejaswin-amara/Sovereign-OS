{
  "$schema": "https://raw.githubusercontent.com/tejaswin-amara/schema/main/config-v14.0.0.json",
  "version": "14.0.0-CloudNative",
  "name": "Sovereign Skills Library",
  "core_axioms": [
    "ponytail",
    "ponytail-audit",
    "ponytail-debt",
    "ponytail-gain",
    "ponytail-help",
    "ponytail-review"
  ],
  "description": "Unified configuration for the Sovereign Master Controller. Single source of truth.",
  "security_policy": {
    "allow_pattern": "^[a-zA-Z0-9_-]{2,50}$",
    "deny_patterns": [
      "\\.\\./",
      "^/",
      "\\\\",
      "\\$\\(",
      "eval\\(",
      "exec\\("
    ],
    "max_skill_name_length": 50,
    "require_signature": true
  },
  "paths": {
    "skills_root": "C:/Skills",
    "core_file": "SOVEREIGN_CORE.md",
    "core_template": "SOVEREIGN_CORE.template.md",
    "version_file": "VERSION",
    "logs_dir": "LOGS",
    "lock_file": ".sovereign.lock"
  },
  "scripts": {
    "sovereign": "sovereign.ps1",
    "sovereign_check": "sovereign-check.ps1",
    "security_sweep": "agent-bootstrap/scripts/security-sweep.ps1",
    "skill_harvester": "agent-bootstrap/scripts/skill-harvester.ps1",
    "validate_skill": "agent-bootstrap/scripts/validate-skill.ps1",
    "install_agent_reach": "agent-bootstrap/scripts/Install-AgentReach.ps1",
    "fetch_cloud_skill": "agent-bootstrap/scripts/Fetch-CloudSkill.ps1",
    "self_evolve": "agent-bootstrap/scripts/self-evolve.ps1",
    "update_checksum": "agent-bootstrap/scripts/update-checksum.ps1",
    "helpers": "agent-bootstrap/scripts/helpers.psm1"
  },
  "governance": {
    "module_cap": 32,
    "module_caps": {
      "network": "restrictive",
      "filesystem": "read-only-cloud",
      "execution_bounds": "docker-only"
    },
    "multi_tenant": {
      "enabled": true,
      "tenant_id": "HQ-Alpha",
      "isolation_mode": "strict",
      "distributed_backends": [
        "tcp://office-ny.sovereign.internal:5000",
        "tcp://office-ldn.sovereign.internal:5000"
      ]
    },
    "skills_count": 2,
    "_skills_count_note": "DYNAMIC - overwritten by sovereign.ps1 at runtime. Never edit manually.",
    "lock_timeout_seconds": 30,
    "lock_lease_timeout_seconds": 600,
    "drift_tolerance": "LOW",
    "maintenance_only": false,
    "log_retention_days": 7,
    "log_max_size_mb": 10,
    "harvester_excluded_dirs": [
      ".git",
      ".agents",
      ".archive-v1.0",
      ".quarantine",
      "agent-bootstrap",
      "LOGS",
      "scratch",
      "templates",
      "servers",
      ".cloud-cache"
    ]
  },
  "mcp_bindings": {
    "allowed": [
      "browsermcp",
      "StitchMCP",
      "Kluster-Verify-Code",
      "android-management-api",
      "chrome-devtools-mcp",
      "fetch",
      "figma",
      "filesystem",
      "firebase-mcp-server",
      "github",
      "github-mcp-server",
      "google-compute-engine",
      "google-developer-knowledge",
      "mcp-knowledge-graph",
      "memory",
      "puppeteer",
      "sequential-thinking",
      "tavily",
      "exa"
    ],
    "forbidden": [
      "mcp-toolbox-for-databases",
      "*"
    ],
    "_note": "Only listed MCPs may be invoked. All others are denied."
  },
  "harvester": {
    "scan_subdirs_on_no_root_manifest": true,
    "monorepo_subdirs": [
      "apps",
      "packages",
      "services"
    ],
    "manifest_files": [
      "package.json",
      "requirements.txt",
      "pyproject.toml",
      "pom.xml",
      "Cargo.toml",
      "go.mod"
    ],
    "excluded_scan_dirs": [
      "node_modules",
      ".git",
      ".agents",
      "dist",
      "build",
      ".next"
    ]
  },
  "dep_to_skill_map": {
    "next": "vercel/next.js",
    "react": "facebook/react",
    "drizzle": "drizzle-team/drizzle-orm",
    "drizzle-orm": "drizzle-team/drizzle-orm",
    "tailwind": "tailwindlabs/tailwindcss",
    "tailwindcss": "tailwindlabs/tailwindcss",
    "trpc": "trpc/trpc",
    "@trpc/server": "trpc/trpc",
    "zod": "colinhacks/zod",
    "hono": "honojs/hono",
    "turbo": "vercel/turbo",
    "playwright": "microsoft/playwright",
    "@playwright/test": "microsoft/playwright",
    "better-auth": "better-auth/better-auth",
    "lucia": "lucia-auth/lucia",
    "expo": "expo/expo",
    "bullmq": "taskforcesh/bullmq",
    "fastify": "fastify/fastify",
    "astro": "withastro/astro",
    "svelte": "sveltejs/svelte",
    "payload": "payloadcms/payload",
    "keycloak": "keycloak/keycloak",
    "fastapi": "fastapi/fastapi",
    "go": "golang/go",
    "bun": "oven-sh/bun",
    "bun-types": "oven-sh/bun",
    "@biomejs/biome": "biomejs/biome",
    "biome": "biomejs/biome",
    "ai": "vercel/ai",
    "@ai-sdk/openai": "vercel/ai",
    "@ai-sdk/anthropic": "vercel/ai",
    "@supabase/supabase-js": "supabase/supabase",
    "supabase": "supabase/supabase",
    "@temporalio/client": "temporalio/sdk-typescript",
    "@temporalio/worker": "temporalio/sdk-typescript",
    "prisma": "prisma/prisma",
    "@prisma/client": "prisma/prisma",
    "vitest": "vitest-dev/vitest",
    "jest": "jestjs/jest",
    "express": "expressjs/express",
    "zustand": "pmndrs/zustand",
    "framer-motion": "framer/motion",
    "tauri": "tauri-apps/tauri",
    "@tauri-apps/api": "tauri-apps/tauri",
    "typespec": "microsoft/typespec",
    "@typespec/compiler": "microsoft/typespec",
    "recharts": "recharts/recharts",
    "firebase": "firebase/firebase-js-sdk",
    "@capacitor/app": "ionic-team/capacitor",
    "@capacitor/dialog": "ionic-team/capacitor",
    "@capacitor/camera": "ionic-team/capacitor",
    "@capacitor/cli": "ionic-team/capacitor",
    "react-dom": "facebook/react",
    "vite": "vitejs/vite",
    "@vitejs/plugin-react": "vitejs/vite",
    "vite-plugin-pwa": "vite-pwa/vite-plugin-pwa",
    "browser-use": "browser-use/browser-use",
    "stagehand": "browserbase/stagehand",
    "mem0": "mem0ai/mem0",
    "zep": "getzep/zep",
    "e2b": "e2b-dev/E2B",
    "daytona": "daytonaio/daytona",
    "autogen": "microsoft/autogen",
    "crewai": "crewAIInc/crewAI",
    "aider": "Aider-AI/aider",
    "langgraph": "langchain-ai/langgraph",
    "llama-index": "run-llama/llama_index",
    "llama_index": "run-llama/llama_index",
    "skyvern": "skyvern-ai/skyvern",
    "crawlee": "apify/crawlee",
    "firecrawl": "mendableai/firecrawl",
    "exa": "exa-labs/exa-py",
    "tavily": "tavily-ai/tavily-python",
    "spider": "spider-rs/spider",
    "jina": "jina-ai/reader",
    "litellm": "BerriAI/litellm",
    "wrangler": "cloudflare/workers-sdk",
    "sst": "sst/sst",
    "openai": "openai/openai-python",
    "anthropic": "anthropics/anthropic-sdk-python",
    "redis": "redis/node-redis",
    "jcode": "1jehuang/jcode",
    "turbovec": "RyanCodrai/turbovec",
    "chemistry": "rdkit/rdkit",
    "genomics": "samtools/htslib",
    "proteins": "deepmind/alphafold",
    "android": "android/architecture-samples",
    "alphafold": "deepmind/alphafold",
    "chembl": "chembl/chembl_webresource_client",
    "chembl-webresource-client": "chembl/chembl_webresource_client",
    "clinvar": "ncbi/clinvar",
    "dbsnp": "ncbi/dbsnp",
    "ensembl": "Ensembl/ensembl-vep",
    "foldseek": "steineggerlab/foldseek",
    "gnomad": "broadinstitute/gnomad-browser",
    "gtex": "broadinstitute/gtex-pipeline",
    "interproscan": "ebi-pf-team/interproscan",
    "arxiv": "lukasschwab/arxiv.py",
    "openfda": "FDA/openfda",
    "opentargets": "opentargets/platform",
    "pymol": "schrodinger/pymol-open-source",
    "graphrag": "microsoft/graphrag",
    "dspy": "stanfordnlp/dspy",
    "pydantic-ai": "pydantic/pydantic-ai",
    "open-interpreter": "OpenInterpreter/open-interpreter",
    "smolagents": "huggingface/smolagents",
    "cline": "cline/cline",
    "dummy": "dummy/test",
    "inferred-package": "test/inferred-package",
    "testrepo": "testorg/testrepo"
  },
  "sandbox": {
    "enabled": true
  }
}
